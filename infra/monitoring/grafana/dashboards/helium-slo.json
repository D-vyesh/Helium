  "liveNow": false,
  "panels": [
    {
      "title": "API Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"helium-core\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"helium-core\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"helium-core\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (5xx / 4xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"helium-core\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"helium-core\",status=~\"4..\"}[5m]))",
          "legendFormat": "4xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Settlement Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(helium_settlement_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 Settlement"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(helium_settlement_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 Settlement"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Outbox Backlog",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "outbox_events_pending",
          "legendFormat": "Pending"
        },
        {
          "expr": "outbox_events_dead_letter",
          "legendFormat": "Dead Letter"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Outbox Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "rate(outbox_events_processed_total[5m])",
          "legendFormat": "Processed/s"
        },
        {
          "expr": "rate(outbox_events_failed_total[5m])",
          "legendFormat": "Failed/s"
        },
        {
          "expr": "rate(outbox_events_dead_letter_total[5m])",
          "legendFormat": "Dead Letter/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "WebSocket Connections & Fanout",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
