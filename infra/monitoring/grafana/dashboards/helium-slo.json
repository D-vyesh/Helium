        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(helium_websocket_fanout_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Fanout P95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Order & Trade Volume",
