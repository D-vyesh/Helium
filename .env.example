HELIUM_ENVIRONMENT=local
HELIUM_HTTP_PORT=8080
HELIUM_DB_URL=jdbc:postgresql://localhost:5432/helium
HELIUM_DB_USERNAME=helium
HELIUM_DB_PASSWORD=helium
HELIUM_DB_POOL_SIZE=20
HELIUM_LOG_LEVEL=INFO
HELIUM_API_KEY_PEPPER=change-me-before-production
HELIUM_API_KEY_PREVIOUS_PEPPER=
HELIUM_API_KEY_SIGNATURE_TTL=5m
HELIUM_OUTBOX_ENABLED=true
HELIUM_OUTBOX_POLL_INTERVAL_MS=1000
HELIUM_TRACE_SAMPLING_PROBABILITY=0.10

POSTGRES_DB=helium
POSTGRES_USER=helium
POSTGRES_PASSWORD=helium
POSTGRES_PORT=5432

REDIS_PORT=6379
HELIUM_REDIS_HOST=localhost
HELIUM_REDIS_PORT=6379
HELIUM_REDIS_PASSWORD=helium-redis-change-me

NEXT_PUBLIC_APP_NAME=HELIUM
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_HELIUM_API_BASE_URL=http://localhost:8080
HELIUM_WEB_PORT=3000

PROMETHEUS_PORT=9090
